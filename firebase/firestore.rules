rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    match /monsters/{docId} {
      allow read: if true;
      allow write: if false;
    }

    /// Catálogo de rarezas (`monsters.rarity` = campo `label`). Editar en consola.
    match /monsters_rarity/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /gatcha_machines/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /sbc/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /owned_monsters/{ownedId} {
      allow read: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.monsterId is string
        && request.resource.data.name is string;
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow update: if false;
    }
  }
}

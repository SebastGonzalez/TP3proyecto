rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    match /monsters/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /gatcha_machines/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /sbc/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
